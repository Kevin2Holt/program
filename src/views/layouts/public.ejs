<%# Public-event layout fragment. Mirrors layouts/main but uses the public
body class and a slimmer header. %>

<% if (stage === 'open') { %>
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'progr.am' %></title>
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/calendar.css" />
</head>
<body class="app-body app-body--public">
  <%- include('../partials/header', { context: 'public' }) %>
  <main class="app-main app-main--public">
    <%- include('../partials/flash') %>
<% } else if (stage === 'close') { %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
<% } %>

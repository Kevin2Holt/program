<%- include('../../../layouts/main', { stage: 'open', layoutContext: 'organizer' }) %>
<section class="page page--calendar-booking-detail">
  <header class="page__header">
    <h1>Booking detail</h1>
    <p class="muted">
      <a href="/events/<%= event.id %>/calendar/bookings">&larr; Back to bookings</a>
    </p>
  </header>

  <section class="booking-detail__meta">
    <h2>Reference</h2>
    <p><code><%= booking.confirmation_ref %></code></p>
    <p>
      Status: <span class="status-pill status-pill--<%= booking.status %>"><%= booking.status %></span>
      &middot; Created: <%= booking.created_at %>
      <% if (booking.updated_at) { %> &middot; Updated: <%= booking.updated_at %><% } %>
    </p>
  </section>

  <section class="booking-detail__registrant">
    <h2>Registrant</h2>
    <% if (booking.registrant && booking.registrant.name) { %>
      <p><strong><%= booking.registrant.name %></strong></p>
      <% if (booking.registrant.phone) { %>
        <p>Phone: <%= booking.registrant.phone %>
          <% if (booking.registrant.contact_method) { %>
            (<%= booking.registrant.contact_method %><% if (booking.registrant.number_type) { %>, <%= booking.registrant.number_type %><% } %>)
          <% } %>
        </p>
      <% } %>
      <% if (booking.email) { %>
        <p>Email: <%= booking.email %></p>
      <% } %>
    <% } else { %>
      <p class="muted">No registrant data captured.</p>
    <% } %>
  </section>

  <section class="booking-detail__selections">
    <h2>Selections</h2>
    <% if (!selections || selections.length === 0) { %>
      <p class="muted">No selections.</p>
    <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Item</th>
            <th>Occurrence</th>
            <th>Type</th>
          </tr>
        </thead>
        <tbody>
          <% selections.forEach(function (sel) { %>
            <tr>
              <td><%= String(sel.selected_date).slice(0, 10) %></td>
              <td><%= sel.item_name_snapshot %></td>
              <td>
                <% if (sel.occurrence_label_snapshot) { %><%= sel.occurrence_label_snapshot %><% } %>
                <% if (sel.occurrence_start_snapshot) { %>
                  <%= sel.occurrence_start_snapshot %><% if (sel.occurrence_end_snapshot) { %>–<%= sel.occurrence_end_snapshot %><% } %>
                <% } %>
              </td>
              <td><%= sel.selection_type %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>

  <% if (booking.notes) { %>
    <section class="booking-detail__notes">
      <h2>Notes</h2>
      <p><%= booking.notes %></p>
    </section>
  <% } %>

  <section class="booking-detail__actions">
    <% if (booking.status === 'active') { %>
      <form method="post" action="/events/<%= event.id %>/calendar/bookings/<%= booking.id %>/cancel"
            onsubmit="return confirm('Cancel this booking? Selections will free up capacity.');">
        <button type="submit" class="button button--danger">Cancel booking</button>
      </form>
    <% } else { %>
      <p class="muted">This booking is already <%= booking.status %>.</p>
    <% } %>
    <p class="muted">Edit / reschedule lands in a later phase.</p>
  </section>
</section>
<%- include('../../../layouts/main', { stage: 'close', layoutContext: 'organizer' }) %>

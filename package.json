{
  "name": "program",
  "version": "0.1.0",
  "private": true,
  "description": "progr.am — event programs and calendar signup module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint \"src/**/*.js\" \"test/**/*.js\"",
    "syntax-check": "node --check src/server.js && find src -name '*.js' -exec node --check {} +"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "connect-pg-simple": "^9.0.1",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "pg": "^8.12.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "nodemon": "^3.1.4"
  }
}
